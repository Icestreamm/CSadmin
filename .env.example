PORT=8787
NODE_ENV=development

# Supabase backend connection (server-side only)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Admin account used by server to call protected RPC/functions.
# This user must exist and be added to public.admin_users.
ADMIN_SUPABASE_EMAIL=admin@example.com
ADMIN_SUPABASE_PASSWORD=replace-with-strong-password

# Choose one password mode:
# 1) Plain password
ADMIN_PAGE_PASSWORD=change-me
# 2) SHA-256 password hash (hex, lowercase)
# ADMIN_PAGE_PASSWORD_HASH=put_hash_here

# Session TTL in minutes
ADMIN_SESSION_TTL_MINUTES=120
